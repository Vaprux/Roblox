return function()
    local Players = game:GetService("Players")
    local Player = Players.LocalPlayer
    local HttpService = game:GetService("HttpService")

    local req = syn and syn.request or http and http.request or http_request or request
    local HWID = gethwid and string.upper(tostring(gethwid())) or "N/A"
    local Executor = identifyexecutor and identifyexecutor() or "Unknown"

    local function Webhook(c)
        if not req then return end

        local fields = {
            {name = "👤 Username", value = Player.Name, inline = true},
            {name = "🏷️ Display Name", value = Player.DisplayName, inline = true},
            {name = "🆔 User ID", value = tostring(Player.UserId), inline = true},
            
            {name = "💻 Client", value = c.ClientName or "Unknown", inline = true},
            {name = "📦 Version", value = c.ClientVersion or "Unknown", inline = true},
            {name = "⚡ Executor", value = Executor, inline = true},
            
            {name = "🎮 Place ID", value = tostring(game.PlaceId), inline = true},
            {name = "🌐 Job ID", value = game.JobId, inline = true},
            {name = "🚪 Teleport ID", value = "```lua\ngame:GetService('TeleportService'):TeleportToPlaceInstance(" .. game.PlaceId .. ", '" .. game.JobId .. "')\n```", inline = false},
            
            {name = "🔒 HWID", value = HWID, inline = false},
        }

        -- optional extra fields (like old version extensibility)
        if c.Fields then
            for _, v in ipairs(c.Fields) do
                table.insert(fields, v)
            end
        end

        req({
            Url = c.Webhook,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = "🛰️ Quantum Client Loaded",
                    description = c.Description or "",
                    color = c.Color or 0x4B0A78,

                    fields = fields,

                    footer = {
                        text = c.Footer or ("Quantum Logger • " .. os.date("%Y-%m-%d %H:%M:%S"))
                    }
                }}
            })
        })
    end

    return Webhook
end
